# Copia este fichero a .env y rellena los valores. .env NUNCA se sube a git.

# --- Email (SMTP) ---
# Para Gmail: usa una "contraseña de aplicación", no tu contraseña normal.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_FROM=tu_correo@gmail.com
EMAIL_TO=tu_correo@gmail.com

# --- Idealista vía RapidAPI (proveedor happyendpoint / idealista17) ---
# La tienes en tu panel de RapidAPI. Es la que usa el conector real.
RAPIDAPI_KEY=

# --- Idealista API oficial (sin usar: no tenemos acceso aprobado) ---
IDEALISTA_API_KEY=
IDEALISTA_API_SECRET=
